{
  "manifest_version": 3,
  "name": "UTC Converter",
  "version": "1.0.0",
  "description": "Instant UTC ↔ Local time conversion with smart parsing",
  "browser_specific_settings": {
    "gecko": {
      "id": "utcconverter@extension",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
